---
import Layout from '../layouts/Layout.astro';
---

<Layout
  lang="ro"
  title="404 - Pagina nu a fost găsită | ISAF"
  description="Pagina pe care o căutați nu există sau a fost mutată."
>
    <div class="min-h-screen flex items-center justify-center bg-gray-950">
      <div class="text-center px-4">
        <div class="text-8xl font-black text-red-600 mb-4">404</div>
        <h1 class="text-2xl font-bold text-white mb-3">Pagina nu a fost găsită</h1>
        <p class="text-gray-400 mb-8 max-w-sm mx-auto">
          Pagina pe care o căutați nu există sau a fost mutată.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          Înapoi acasă
        </a>
      </div>
    </div>
</Layout>
