---
import Layout from "../layouts/Layout.astro";
import { getLocalizedPath } from "../i18n/site";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const locale = Astro.url.pathname.includes(`${basePath}en`) ? "en" : "ro";
const copy = locale === "en"
  ? {
      title: "404 - Page not found | ISAF",
      description: "The page you are looking for does not exist or has been moved.",
      heading: "Page not found",
      button: "Back home",
    }
  : {
      title: "404 - Pagina nu a fost găsită | ISAF",
      description: "Pagina pe care o căutați nu există sau a fost mutată.",
      heading: "Pagina nu a fost găsită",
      button: "Înapoi acasă",
    };
---

<Layout
  locale={locale}
  title={copy.title}
  description={copy.description}
>
    <div class="min-h-screen flex items-center justify-center bg-gray-950">
      <div class="text-center px-4">
        <div class="text-8xl font-black text-red-600 mb-4">404</div>
        <h1 class="text-2xl font-bold text-white mb-3">{copy.heading}</h1>
        <p class="text-gray-400 mb-8 max-w-sm mx-auto">
          {copy.description}
        </p>
        <a
          href={getLocalizedPath(locale, "home")}
          class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          {copy.button}
        </a>
      </div>
    </div>
</Layout>
