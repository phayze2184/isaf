---
import { Image } from "astro:assets";
import type { Locale } from "../i18n/site";
import { siteContent } from "../i18n/site";
import heroVideoPoster from "../assets/ISAF_304.jpg";

interface Props {
  locale?: Locale;
}

const { locale = "ro" } = Astro.props;
const content = siteContent[locale].hero;
const stats = content.stats;
---

<section class="hero-isaf relative min-h-screen flex flex-col items-center justify-center overflow-hidden bg-gray-950">
  <div class="absolute inset-0 z-0">
    <div class="hero-bg w-full h-full"></div>
    <div class="hero-grid absolute inset-0"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 text-center">
    <div class="inline-flex items-center gap-2 bg-red-600/10 border border-red-600/25 rounded-full px-4 py-1.5 mb-8">
      <div class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse"></div>
      <span class="text-red-400 text-xs font-semibold uppercase tracking-widest">{content.badge}</span>
    </div>

    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white leading-[1.05] tracking-tight mb-6">
      {content.titlePrefix}{" "}
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-red-400">
        {content.titleHighlight}
      </span>
    </h1>

    <p class="max-w-2xl mx-auto text-lg sm:text-xl text-gray-400 leading-relaxed mb-10">
      {content.description}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#products"
        class="inline-flex w-full max-w-xs items-center justify-center gap-2 bg-red-600 px-7 py-3.5 text-sm font-semibold text-white transition-all hover:scale-[1.02] hover:bg-red-700 active:scale-[0.98] rounded-lg sm:w-56 sm:max-w-none"
      >
        {content.primaryCta}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
      </a>
      <a
        href="#contact"
        class="inline-flex w-full max-w-xs items-center justify-center gap-2 rounded-lg border border-white/20 px-7 py-3.5 text-sm font-semibold text-white/80 transition-all hover:border-white/40 hover:text-white sm:w-56 sm:max-w-none"
      >
        {content.secondaryCta}
      </a>
    </div>

    <div class="hero-video-shell mx-auto mt-14 max-w-3xl">
      <a
        href={content.video.url}
        target="_blank"
        rel="noopener noreferrer"
        class="hero-video-card group relative block overflow-hidden rounded-[2rem] border border-white/12 bg-white/6 p-3 text-left shadow-[0_24px_80px_rgba(0,0,0,0.34)]"
      >
        <div class="relative overflow-hidden rounded-[1.45rem]">
          <Image
            src={heroVideoPoster}
            alt={content.video.alt}
            class="aspect-[16/10] w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) calc(100vw - 2rem), 768px"
            format="webp"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(4,8,16,0.06)_0%,rgba(4,8,16,0.18)_36%,rgba(3,6,12,0.7)_100%)]"></div>
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(220,38,38,0.18),transparent_42%)]"></div>

          <div class="absolute left-4 top-4 inline-flex items-center gap-2 rounded-full border border-white/12 bg-black/35 px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.24em] text-white/82 backdrop-blur-md sm:left-5 sm:top-5">
            <span class="h-2 w-2 rounded-full bg-red-500 shadow-[0_0_18px_rgba(239,68,68,0.9)]"></span>
            {content.video.badge}
          </div>

          <div class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-4 p-5 sm:p-6">
            <div class="max-w-lg">
              <div class="text-lg font-black text-white sm:text-2xl">
                {content.video.title}
              </div>
              <p class="mt-2 max-w-md text-sm leading-relaxed text-white/72 sm:text-base">
                {content.video.description}
              </p>
            </div>

            <div class="hero-play-button flex h-16 w-16 flex-shrink-0 items-center justify-center rounded-full border border-white/18 bg-white/12 text-white shadow-[0_20px_40px_rgba(0,0,0,0.24)] backdrop-blur-md transition-all duration-300 group-hover:scale-105 group-hover:bg-red-600/90 group-hover:border-red-400/80 sm:h-20 sm:w-20">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="ml-1 sm:h-8 sm:w-8">
                <path d="M8 6.82v10.36a1 1 0 0 0 1.53.85l8.14-5.18a1 1 0 0 0 0-1.7L9.53 5.97A1 1 0 0 0 8 6.82Z"></path>
              </svg>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-between gap-4 px-1 pt-4">
          <div class="text-[11px] font-semibold uppercase tracking-[0.26em] text-white/42">
            YouTube
          </div>
          <div class="inline-flex items-center gap-2 text-sm font-semibold text-white/88 transition-colors group-hover:text-white">
            {content.video.cta}
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17 17 7"></path>
              <path d="M7 7h10v10"></path>
            </svg>
          </div>
        </div>
      </a>
    </div>

    <div class="mt-16 grid grid-cols-3 gap-8 max-w-lg mx-auto">
      {stats.map((stat) => (
        <div class="text-center">
          <div
            class="hero-stat-value text-2xl sm:text-3xl font-black text-white mb-1"
            data-stat-value
            data-target={stat.number}
            aria-label={stat.number}
          >
            {stat.number}
          </div>
          <div class="hero-stat-label text-xs text-gray-500 font-medium uppercase tracking-wide">
            {stat.mobileLabel ? (
              <>
                <span class="sm:hidden">{stat.mobileLabel}</span>
                <span class="hidden sm:inline">{stat.label}</span>
              </>
            ) : (
              stat.label
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero-isaf {
    background-color: #05070d;
    isolation: isolate;
  }

  .hero-isaf::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(6, 8, 14, 0.36) 0%,
        rgba(6, 8, 14, 0.14) 14%,
        rgba(6, 8, 14, 0) 32%
      );
  }

  .hero-bg {
    background-color: #07080f;
    background-image:
      radial-gradient(
        ellipse 132% 98% at 50% -22%,
        rgba(138, 18, 33, 0.44) 0%,
        rgba(108, 14, 25, 0.32) 30%,
        rgba(67, 9, 17, 0.15) 54%,
        rgba(9, 10, 16, 0) 82%
      ),
      radial-gradient(
        ellipse 80% 66% at 52% 16%,
        rgba(144, 18, 32, 0.27) 0%,
        rgba(120, 15, 26, 0.16) 34%,
        rgba(15, 11, 18, 0) 76%
      ),
      radial-gradient(
        ellipse 52% 46% at 79% 92%,
        rgba(108, 14, 24, 0.22) 0%,
        rgba(20, 10, 16, 0.04) 56%,
        rgba(6, 8, 14, 0) 86%
      ),
      linear-gradient(
        180deg,
        #0a0b12 0%,
        #090913 40%,
        #070913 70%,
        #06070f 100%
      ),
      linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.72) 0%,
        rgba(0, 0, 0, 0.26) 14%,
        rgba(0, 0, 0, 0) 34%,
        rgba(0, 0, 0, 0) 66%,
        rgba(0, 0, 0, 0.28) 86%,
        rgba(0, 0, 0, 0.74) 100%
      );
    background-size: 100% 100%;
    background-repeat: no-repeat;
  }

  .hero-grid {
    background-image:
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.04) 0,
        rgba(255, 255, 255, 0.04) 1px,
        rgba(150, 32, 46, 0.024) 1px,
        rgba(150, 32, 46, 0.024) 80px
      ),
      repeating-linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.032) 0,
        rgba(255, 255, 255, 0.032) 1px,
        rgba(150, 32, 46, 0.02) 1px,
        rgba(150, 32, 46, 0.02) 80px
      ),
      linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.38) 0%,
        rgba(0, 0, 0, 0.08) 22%,
        rgba(0, 0, 0, 0.06) 72%,
        rgba(0, 0, 0, 0.46) 100%
      );
    background-size:
      80px 80px,
      80px 80px,
      100% 100%;
    background-repeat: repeat, repeat, no-repeat;
    pointer-events: none;
  }

  .hero-stat-value {
    display: inline-block;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    opacity: 0;
    transform: translateY(0.75em);
    filter: blur(10px);
    transition:
      opacity 380ms ease,
      transform 900ms cubic-bezier(0.19, 1, 0.22, 1),
      filter 900ms cubic-bezier(0.19, 1, 0.22, 1);
    will-change: transform, opacity, filter;
  }

  .hero-stat-value.is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  .hero-stat-label {
    opacity: 0;
    transform: translateY(1.1em);
    filter: blur(8px);
    transition:
      opacity 360ms ease,
      transform 900ms cubic-bezier(0.19, 1, 0.22, 1),
      filter 900ms cubic-bezier(0.19, 1, 0.22, 1);
    transition-delay: 160ms;
    will-change: transform, opacity, filter;
  }

  .hero-stat-label.is-visible {
    opacity: 1;
    transform: translateY(0);
    filter: blur(0);
  }

  .hero-video-shell {
    position: relative;
  }

  .hero-video-shell::before {
    content: "";
    position: absolute;
    inset: 1.5rem 2.25rem -1.25rem;
    border-radius: 2rem;
    background:
      radial-gradient(circle at top, rgba(220, 38, 38, 0.22), transparent 42%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0));
    filter: blur(28px);
    opacity: 0.9;
    z-index: -1;
  }

  .hero-video-card {
    transform: translateZ(0);
    transition:
      transform 360ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 260ms ease,
      box-shadow 360ms cubic-bezier(0.22, 1, 0.36, 1),
      background-color 260ms ease;
  }

  .hero-video-card:hover {
    transform: translateY(-4px);
    border-color: rgba(248, 113, 113, 0.34);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.4);
  }

  .hero-play-button {
    position: relative;
  }

  .hero-play-button::before {
    content: "";
    position: absolute;
    inset: -10px;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    opacity: 0.6;
    transition:
      transform 320ms ease,
      border-color 320ms ease,
      opacity 320ms ease;
  }

  .hero-video-card:hover .hero-play-button::before {
    transform: scale(1.08);
    border-color: rgba(248, 113, 113, 0.4);
    opacity: 0.95;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-video-card,
    .hero-video-card:hover,
    .hero-play-button::before,
    .hero-video-card:hover .hero-play-button::before {
      transform: none;
      transition: none;
    }

    .hero-stat-value {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }

    .hero-stat-label {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>

<script>
  type CounterStat = {
    element: HTMLElement;
    label: HTMLElement | null;
    targetValue: number;
    suffix: string;
  };

  const statValues = document.querySelectorAll<HTMLElement>("[data-stat-value]");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const parseStat = (element: HTMLElement): CounterStat | null => {
    const target = element.getAttribute("data-target") ?? element.textContent?.trim() ?? "";
    const numericValue = target.replace(/[^\d]/g, "");

    if (!numericValue) return null;

    return {
      element,
      label: element.parentElement?.querySelector<HTMLElement>(".hero-stat-label") ?? null,
      targetValue: Number.parseInt(numericValue, 10),
      suffix: target.replace(/\d/g, ""),
    };
  };

  const animateStat = (stat: CounterStat) => {
    const { element, label, targetValue, suffix } = stat;
    element.dataset.animated = "true";

    const reveal = () => {
      element.classList.add("is-visible");
      label?.classList.add("is-visible");
    };

    if (prefersReducedMotion) {
      element.textContent = `${targetValue}${suffix}`;
      reveal();
      return;
    }

    const duration = 1600;
    const start = performance.now();

    const step = (timestamp: number) => {
      const elapsed = timestamp - start;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - (1 - progress) ** 3;
      const currentValue = Math.round(targetValue * eased);

      element.textContent = `${currentValue}${suffix}`;

      if (progress < 1) {
        window.requestAnimationFrame(step);
        return;
      }

      element.textContent = `${targetValue}${suffix}`;
    };

    reveal();
    window.requestAnimationFrame(step);
  };

  const statsObserver = new IntersectionObserver(
    (entries, observer) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const stat = parseStat(entry.target as HTMLElement);
        if (!stat || stat.element.dataset.animated === "true") return;

        animateStat(stat);
        observer.unobserve(stat.element);
      });
    },
    { threshold: 0.45 },
  );

  statValues.forEach((element) => {
    const stat = parseStat(element);

    if (!stat) return;

    if (prefersReducedMotion) {
      animateStat(stat);
      return;
    }

    statsObserver.observe(element);
  });
</script>
