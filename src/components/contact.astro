---
import { AlertCircle, CheckCircle, MapPin, Phone, Printer, Send } from "lucide-react";
import type { Locale } from "../i18n/site";
import { getBasePath, siteContent } from "../i18n/site";

interface Props {
  locale?: Locale;
}

const { locale = "ro" } = Astro.props;
const content = siteContent[locale].contact;

const locationInfo = [
  {
    icon: MapPin,
    ...content.locationInfo[0],
    href: "https://www.google.com/maps?q=Strada+Lugoj+68,+București,+România",
  },
  {
    icon: MapPin,
    ...content.locationInfo[1],
    href: "https://www.google.com/maps?q=Strada+Copșa+Mică+25,+București,+România",
  },
];

const phoneFaxInfo = [
  {
    icon: Phone,
    ...content.phoneFaxInfo[0],
    href: "tel:+40212208075",
  },
  {
    icon: Printer,
    ...content.phoneFaxInfo[1],
    href: "tel:+40374092239",
  },
];

const contactStatus = Astro.url.searchParams.get("contact");
const showSuccess = contactStatus === "success";
const showError = contactStatus === "error";
const resetHref = `${Astro.url.pathname}#contact`;
const apiPath = `${getBasePath()}api/contact`;
---

<section id="contact" class="py-20 lg:py-28 bg-gray-950">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-5 gap-16">
      <div class="lg:col-span-2">
        <div class="inline-flex items-center gap-2 text-red-500 font-semibold text-sm uppercase tracking-widest mb-4">
          <div class="w-8 h-0.5 bg-red-500"></div>
          {content.eyebrow}
        </div>
        <h2 class="text-3xl sm:text-4xl font-black text-white leading-tight mb-4">
          {content.title}
        </h2>
        <p class="text-gray-400 leading-relaxed mb-10">
          {content.description}
        </p>

        <div class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {locationInfo.map((info) => {
              const Icon = info.icon;

              return (
                <div class="flex items-start gap-4">
                  <div class="w-9 h-9 bg-red-600/15 border border-red-600/25 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                    <Icon size={15} className="text-red-500" />
                  </div>
                  <div>
                    <div class="text-gray-500 text-xs font-medium uppercase tracking-wide mb-0.5">{info.label}</div>
                    <a href={info.href} class="text-white font-medium text-sm hover:text-red-400 transition-colors">
                      {info.value}
                    </a>
                  </div>
                </div>
              );
            })}
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {phoneFaxInfo.map((info) => {
              const Icon = info.icon;

              return (
                <div class="flex items-start gap-4">
                  <div class="w-9 h-9 bg-red-600/15 border border-red-600/25 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5">
                    <Icon size={15} className="text-red-500" />
                  </div>
                  <div>
                    <div class="text-gray-500 text-xs font-medium uppercase tracking-wide mb-0.5">{info.label}</div>
                    <a href={info.href} class="text-white font-medium text-sm hover:text-red-400 transition-colors">
                      {info.value}
                    </a>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="mt-10 p-5 rounded-xl border border-white/8 bg-white/4">
          <div class="text-white font-semibold text-sm mb-2">{content.scheduleTitle}</div>
          <div class="space-y-1 text-sm">
            {content.schedule.map((item) => (
              <div class="flex justify-between">
                <span class="text-gray-400">{item.days}</span>
                <span class={item.hours === "Închis" || item.hours === "Closed" ? "text-gray-500" : "text-gray-300"}>
                  {item.hours}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="lg:col-span-3">
        <div class="bg-white rounded-2xl p-7 sm:p-8">
          <div
            class="flex flex-col items-center justify-center text-center py-12"
            data-contact-success
            hidden={!showSuccess}
          >
            <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mb-4">
              <CheckCircle size={32} className="text-green-600" />
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{content.successTitle}</h3>
            <p class="text-gray-500 text-sm max-w-xs">
              {content.successDescription}
            </p>
            <a
              href={resetHref}
              class="mt-6 text-red-600 hover:text-red-700 font-semibold text-sm"
              data-reset-contact
            >
              {content.sendAnotherMessage}
            </a>
          </div>

          <div data-contact-form-panel hidden={showSuccess}>
            <div
              class:list={[
                "mb-5 flex items-start gap-3 rounded-xl border px-4 py-3 text-sm",
                showError
                  ? "border-red-200 bg-red-50 text-red-700"
                  : "hidden border-red-200 bg-red-50 text-red-700",
              ]}
              data-contact-status
              role="alert"
              aria-live="polite"
            >
              <AlertCircle size={18} className="mt-0.5 flex-shrink-0" />
              <div data-contact-status-text>
                {content.genericError}
              </div>
            </div>

            <form
              action={apiPath}
              method="POST"
              class="space-y-4"
              data-contact-form
            >
              <h3 class="text-lg font-bold text-gray-900 mb-5">{content.formTitle}</h3>

              <input
                type="text"
                name="website"
                class="hidden"
                tabindex="-1"
                autocomplete="off"
                aria-hidden="true"
              />
              <input type="hidden" name="locale" value={locale} />

              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label for="contact-name" class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">
                    {content.fields.name}
                  </label>
                  <input
                    id="contact-name"
                    name="name"
                    required
                    type="text"
                    autocomplete="name"
                    placeholder={content.placeholders.name}
                    class="w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-red-400 focus:ring-1 focus:ring-red-400 transition-colors"
                  />
                </div>

                <div>
                  <label for="contact-company" class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">
                    {content.fields.company}
                  </label>
                  <input
                    id="contact-company"
                    name="company"
                    type="text"
                    autocomplete="organization"
                    placeholder={content.placeholders.company}
                    class="w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-red-400 focus:ring-1 focus:ring-red-400 transition-colors"
                  />
                </div>
              </div>

              <div>
                <label for="contact-email" class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">
                  {content.fields.email}
                </label>
                <input
                  id="contact-email"
                  name="email"
                  required
                  type="email"
                  autocomplete="email"
                  placeholder={content.placeholders.email}
                  class="w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-red-400 focus:ring-1 focus:ring-red-400 transition-colors"
                />
              </div>

              <div>
                <label for="contact-subject" class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">
                  {content.fields.subject}
                </label>
                <select
                  id="contact-subject"
                  name="subject"
                  required
                  class="w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:border-red-400 focus:ring-1 focus:ring-red-400 transition-colors bg-white"
                >
                  <option value="">{content.subjectPlaceholder}</option>
                  {content.subjectOptions.map((option) => (
                    <option>{option}</option>
                  ))}
                </select>
              </div>

              <div>
                <label for="contact-message" class="block text-xs font-semibold text-gray-600 mb-1.5 uppercase tracking-wide">
                  {content.fields.message}
                </label>
                <textarea
                  id="contact-message"
                  name="message"
                  required
                  rows="4"
                  placeholder={content.placeholders.message}
                  class="w-full border border-gray-200 rounded-lg px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:border-red-400 focus:ring-1 focus:ring-red-400 transition-colors resize-none"
                ></textarea>
              </div>

              <button
                type="submit"
                class="w-full flex items-center justify-center gap-2 bg-red-600 hover:bg-red-700 disabled:bg-red-400 text-white font-semibold py-3 rounded-lg transition-colors text-sm"
                data-submit-button
              >
                <span class="hidden w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin" data-submit-spinner></span>
                <span class="inline-flex items-center gap-2" data-idle-label>
                  <Send size={15} />
                  {content.submitLabel}
                </span>
                <span class="hidden" data-loading-label>{content.loadingLabel}</span>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ submitFailedMessage: content.jsErrors.submitFailed, networkFailedMessage: content.jsErrors.networkFailed }}>
  const form = document.querySelector("[data-contact-form]");
  const formPanel = document.querySelector("[data-contact-form-panel]");
  const successPanel = document.querySelector("[data-contact-success]");
  const statusBox = document.querySelector("[data-contact-status]");
  const statusText = document.querySelector("[data-contact-status-text]");
  const submitButton = document.querySelector("[data-submit-button]");
  const submitSpinner = document.querySelector("[data-submit-spinner]");
  const idleLabel = document.querySelector("[data-idle-label]");
  const loadingLabel = document.querySelector("[data-loading-label]");
  const resetLink = document.querySelector("[data-reset-contact]");

  const setLoading = (isLoading) => {
    if (!(submitButton instanceof HTMLButtonElement)) return;
    submitButton.disabled = isLoading;
    submitSpinner?.classList.toggle("hidden", !isLoading);
    idleLabel?.classList.toggle("hidden", isLoading);
    loadingLabel?.classList.toggle("hidden", !isLoading);
  };

  const showError = (message) => {
    statusBox?.classList.remove("hidden");
    if (statusText) statusText.textContent = message;
  };

  const hideError = () => {
    statusBox?.classList.add("hidden");
  };

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!(form instanceof HTMLFormElement)) return;

    hideError();
    setLoading(true);

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: {
          Accept: "application/json",
        },
      });

      const result = await response.json().catch(() => null);

      if (!response.ok || !result?.ok) {
        showError(result?.error ?? submitFailedMessage);
        return;
      }

      form.reset();
      formPanel?.setAttribute("hidden", "");
      successPanel?.removeAttribute("hidden");
      window.dispatchEvent(new CustomEvent("isaf:contact_success"));
      history.replaceState(null, "", "#contact");
    } catch (_error) {
      showError(networkFailedMessage);
    } finally {
      setLoading(false);
    }
  });

  resetLink?.addEventListener("click", (event) => {
    event.preventDefault();
    hideError();
    form?.reset();
    successPanel?.setAttribute("hidden", "");
    formPanel?.removeAttribute("hidden");
    history.replaceState(null, "", "#contact");
  });
</script>
