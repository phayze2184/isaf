---
import type { Locale, PageKey } from "../i18n/site";
import {
  getAlternateLocale,
  getLocalizedPath,
  siteContent,
} from "../i18n/site";

interface Props {
  locale?: Locale;
  currentPage?: PageKey;
}

const { locale = "ro", currentPage = "home" } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const content = siteContent[locale].navbar;
const homePath = getLocalizedPath(locale, "home");
const navLinks = content.links.map((link) => ({
  ...link,
  href:
    currentPage === "home" ? link.href : getLocalizedPath(locale, "home", link.href),
}));
const compactNavLinks = navLinks.filter(
  (link) => !link.href.endsWith("#why-isaf") && !link.href.endsWith("#contact"),
);
const contactHref =
  currentPage === "home" ? "#contact" : getLocalizedPath(locale, "home", "#contact");
const switchHref = getLocalizedPath(getAlternateLocale(locale), currentPage);
---

<header id="navbar" class="navbar-bg-isaf fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href={homePath} class="flex items-center gap-2">
        <img
          src={`${basePath}logo-isaf.png`}
          alt="ISAF logo"
          class="h-20 w-20 flex-shrink-0 object-contain sm:h-24 sm:w-24"
        />
      </a>

      <nav class="hidden lg:flex items-center gap-8">
        {navLinks.map((link) => (
          <a href={link.href} class="nav-link text-sm font-medium transition-colors">
            {link.label}
          </a>
        ))}
      </nav>

      <div class="hidden lg:flex items-center gap-3">
        <a
          href={switchHref}
          class="language-switch inline-flex items-center justify-center text-sm font-semibold px-3.5 py-2.5 rounded transition-colors"
          aria-label={content.switchAriaLabel}
        >
          {content.switchLabel}
        </a>
        <a href={contactHref} class="bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-5 py-2.5 rounded transition-colors">
          {content.cta}
        </a>
      </div>

      <div class="flex items-center gap-2 lg:hidden">
        <a
          href={switchHref}
          class="language-switch inline-flex items-center justify-center text-sm font-semibold px-3.5 py-2.5 rounded transition-colors"
          aria-label={content.switchAriaLabel}
        >
          {content.switchLabel}
        </a>
        <button id="menu-btn" class="nav-menu-btn p-2 rounded transition-colors">
          <svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="18" y2="18"></line>
          </svg>
          <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <path d="M18 6 6 18"></path><path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden shadow-lg">
    <div class="px-4 py-4 flex flex-col gap-1">
      {compactNavLinks.map((link) => (
        <a href={link.href} class="mobile-link text-left font-medium py-2.5 px-3 rounded transition-colors text-sm">
          {link.label}
        </a>
      ))}
      <a href={contactHref} class="mt-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold px-4 py-2.5 rounded transition-colors text-center">
        {content.cta}
      </a>
    </div>
  </div>
</header>

<script>
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    navbar?.classList.toggle("scrolled", window.scrollY > 20);
  }, { passive: true });

  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconHamburger = document.getElementById("icon-hamburger");
  const iconClose = document.getElementById("icon-close");

  menuBtn?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden", isOpen);
    iconHamburger?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
  });

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      iconHamburger?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    });
  });
</script>

<style>
  .navbar-bg-isaf {
    background-color: transparent;
    background-image: none;
    backdrop-filter: none;
    box-shadow: none;
    transition:
      background-color 360ms cubic-bezier(0.22, 1, 0.36, 1),
      background-image 360ms cubic-bezier(0.22, 1, 0.36, 1),
      backdrop-filter 360ms cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 360ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 360ms cubic-bezier(0.22, 1, 0.36, 1);
    border-bottom: 1px solid transparent;
  }

  .navbar-bg-isaf.scrolled {
    background-color: rgba(255, 255, 255, 0.94);
    background-image: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.97) 0%,
      rgba(255, 255, 255, 0.94) 100%
    );
    backdrop-filter: blur(12px) saturate(170%);
    box-shadow: 0 12px 30px rgba(2, 8, 20, 0.14);
    border-bottom-color: rgba(15, 23, 42, 0.08);
  }

  .nav-link {
    color: rgba(255, 255, 255, 0.94);
    text-shadow: 0 1px 14px rgba(4, 8, 16, 0.35);
  }

  .nav-link:hover {
    color: #ef4444;
  }

  .nav-menu-btn {
    color: rgba(255, 255, 255, 0.94);
    text-shadow: 0 1px 14px rgba(4, 8, 16, 0.35);
  }

  .language-switch {
    color: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.08);
    text-shadow: 0 1px 14px rgba(4, 8, 16, 0.35);
  }

  .language-switch:hover {
    border-color: rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.14);
  }

  .navbar-bg-isaf.scrolled .nav-link {
    color: #1f2937;
    text-shadow: none;
  }

  .navbar-bg-isaf.scrolled .nav-link:hover {
    color: #dc2626;
  }

  .navbar-bg-isaf.scrolled .nav-menu-btn {
    color: #1f2937;
    text-shadow: none;
  }

  .navbar-bg-isaf.scrolled .language-switch {
    color: #1f2937;
    border-color: rgba(15, 23, 42, 0.12);
    background: rgba(255, 255, 255, 0.7);
    text-shadow: none;
  }

  .navbar-bg-isaf.scrolled .language-switch:hover {
    border-color: rgba(220, 38, 38, 0.28);
    color: #dc2626;
  }

  #mobile-menu {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    background-image:
      linear-gradient(
        180deg,
        rgba(24, 7, 11, 0.98) 0%,
        rgba(11, 11, 15, 0.98) 100%
      ),
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.35) 0%,
        rgba(0, 0, 0, 0.55) 100%
      );
    background-size:
      100% 100%,
      80px 80px,
      80px 80px,
      100% 100%;
    background-repeat: no-repeat, repeat, repeat, no-repeat;
  }

  .mobile-link {
    color: rgba(255, 255, 255, 0.94);
  }

  .mobile-link:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .navbar-bg-isaf.scrolled #mobile-menu {
    border-top-color: rgba(15, 23, 42, 0.08);
    background-image: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.98) 0%,
      rgba(255, 255, 255, 0.96) 100%
    );
    background-repeat: no-repeat;
    box-shadow: 0 16px 40px rgba(2, 8, 20, 0.12);
  }

  .navbar-bg-isaf.scrolled .mobile-link {
    color: #1f2937;
  }

  .navbar-bg-isaf.scrolled .mobile-link:hover {
    background-color: rgba(15, 23, 42, 0.06);
  }
</style>
