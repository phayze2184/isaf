---
import { Image } from "astro:assets";
import { Shield, Award, Globe, Zap } from "lucide-react";
import clientiIsafImage from "../assets/clienti-isaf.webp";
import type { Locale } from "../i18n/site";
import { siteContent } from "../i18n/site";

interface Props {
  locale?: Locale;
}

const { locale = "ro" } = Astro.props;
const content = siteContent[locale].about;
const values = [
  { Icon: Shield, ...content.values[0] },
  { Icon: Award, ...content.values[1] },
  { Icon: Globe, ...content.values[2] },
  { Icon: Zap, ...content.values[3] },
];
---

<section id="about" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <div class="inline-flex items-center gap-2 text-red-600 font-semibold text-sm uppercase tracking-widest mb-4">
          <div class="w-8 h-0.5 bg-red-600"></div>
          {content.eyebrow}
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-gray-900 leading-tight mb-6">
          {content.title}
        </h2>
        <p class="text-gray-600 text-lg leading-relaxed mb-6">
          {content.paragraphs[0]}
        </p>
        <p class="text-gray-600 leading-relaxed mb-8">
          {content.paragraphs[1]}
        </p>
        <div class="flex flex-wrap gap-3">
          {content.badges.map((badge) => (
            <span class="bg-red-50 text-red-700 border border-red-100 text-xs font-semibold px-3 py-1.5 rounded-full">
              {badge}
            </span>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        {values.map(({ Icon, title, description }) => (
          <div class="bg-gray-50 border border-gray-100 rounded-xl p-5 hover:border-red-200 hover:bg-red-50/30 transition-colors group">
            <div class="w-10 h-10 bg-red-100 group-hover:bg-red-600 rounded-lg flex items-center justify-center mb-3 transition-colors">
              <Icon size={18} className="text-red-600 group-hover:text-white transition-colors" />
            </div>
            <h3 class="font-bold text-gray-900 text-sm mb-1.5">{title}</h3>
            <p class="text-gray-500 text-xs leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-16">
      <div class="overflow-hidden rounded-3xl border border-gray-200 bg-gray-50 shadow-sm">
        <Image
          src={clientiIsafImage}
          alt={content.imageAlt}
          class="h-auto w-full object-contain"
          widths={[768, 1200, 1600]}
          sizes="(max-width: 768px) 100vw, 1200px"
          format="webp"
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>
